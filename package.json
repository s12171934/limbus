{
  "name": "limbus-deck",
  "private": true,
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "check": "turbo check",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "quality": "biome check .",
    "quality:fix": "biome check --write .",
    "test": "turbo test",
    "deploy": "turbo deploy"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "turbo": "2.10.5",
    "typescript": "7.0.2"
  }
}
